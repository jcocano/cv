{
  "name": "cv",
  "version": "1.0.0",
  "description": "CV y portfolio personal de Jesus Cocano. Astro + TypeScript estricto.",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "typecheck": "astro check",
    "lint": "eslint \"src/**/*.{ts,astro,mjs,cjs,js}\"",
    "format": "prettier --write \"**/*.{ts,astro,mjs,cjs,js,json,md,css}\"",
    "format:check": "prettier --check \"**/*.{ts,astro,mjs,cjs,js,json,md,css}\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepare": "husky"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jcocano/cv.git"
  },
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/jcocano/cv/issues"
  },
  "homepage": "https://github.com/jcocano/cv#readme",
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.6.0",
    "@typescript-eslint/eslint-plugin": "^8.59.1",
    "@typescript-eslint/parser": "^8.59.1",
    "astro": "^6.2.1",
    "astro-eslint-parser": "^1.4.0",
    "eslint": "^10.3.0",
    "eslint-plugin-astro": "^1.7.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "prettier-plugin-astro": "^0.14.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.1",
    "vitest": "^4.1.5"
  }
}
