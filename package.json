{
  "name": "cv",
  "version": "1.0.0",
  "description": "CV y portfolio personal de Jesus Cocano. Astro + TypeScript estricto.",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "astro dev",
    "build": "astro build && npm run build:status",
    "build:status": "node scripts/generate-status.mjs",
    "preview": "astro preview",
    "typecheck": "astro check",
    "lint": "eslint \"src/**/*.{ts,astro,mjs,cjs,js}\" \"tests/**/*.{ts,astro,mjs,cjs,js}\" \"tooling/**/*.{ts,mjs,cjs,js}\" \"scripts/**/*.{ts,mjs,cjs,js}\"",
    "format": "prettier --write \"**/*.{ts,astro,mjs,cjs,js,json,md,css}\"",
    "format:check": "prettier --check \"**/*.{ts,astro,mjs,cjs,js,json,md,css}\"",
    "check:styles": "bash -c 'matches=$(grep -rEn \"<style\" src/components src/layouts 2>/dev/null | grep -v \"is:global\" || true); if [ -n \"$matches\" ]; then echo \"ERROR: Found <style> blocks in components/layouts (use <Componente>.module.css instead, see docs/conventions.md §3):\"; echo \"$matches\"; exit 1; fi'",
    "pretest": "node tooling/sync-data-store.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:visual": "node tooling/test-visual.mjs",
    "prepare": "husky"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jcocano/cv.git"
  },
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/jcocano/cv/issues"
  },
  "homepage": "https://github.com/jcocano/cv#readme",
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@astrojs/mdx": "^5.0.4",
    "@axe-core/playwright": "^4.11.3",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.59.1",
    "@types/jsdom": "^28.0.1",
    "@types/node": "^25.6.0",
    "@typescript-eslint/eslint-plugin": "^8.59.1",
    "@typescript-eslint/parser": "^8.59.1",
    "astro": "^6.2.1",
    "astro-eslint-parser": "^1.4.0",
    "axe-core": "^4.11.4",
    "eslint": "^10.3.0",
    "eslint-plugin-astro": "^1.7.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "prettier-plugin-astro": "^0.14.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.1",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "@fontsource-variable/geist": "^5.2.8",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@fontsource/geist": "^5.2.8",
    "zod": "^4.4.2"
  }
}
