---
import styles from './SpacingScale.module.css';

type SpacingPreviewKey = 'radius' | 'radius-lg' | 'container';

interface SpacingEntry {
  readonly id: string;
  readonly token: string;
  readonly value: string;
  readonly previewKey: SpacingPreviewKey;
}

const ENTRIES: ReadonlyArray<SpacingEntry> = [
  { id: 'spacing-radius', token: '--radius', value: '8px', previewKey: 'radius' },
  { id: 'spacing-radius-lg', token: '--radius-lg', value: '14px', previewKey: 'radius-lg' },
  { id: 'spacing-container', token: '--container', value: '1180px', previewKey: 'container' },
];
---

<div class={styles.specGrid}>
  {
    ENTRIES.map((entry) => (
      <article class={styles.cell} data-spec-cell={entry.id}>
        <div class={styles.label}>
          <h4 class={styles.tokenName} id={entry.id}>
            {entry.token}
          </h4>
          <span class={styles.value}>{entry.value}</span>
        </div>
        <div class={styles.stage}>
          {entry.previewKey === 'radius' && (
            <div class={`${styles.radiusDemo} ${styles.radiusDemoSm}`} aria-hidden="true" />
          )}
          {entry.previewKey === 'radius-lg' && (
            <div class={`${styles.radiusDemo} ${styles.radiusDemoLg}`} aria-hidden="true" />
          )}
          {entry.previewKey === 'container' && <div class={styles.containerDemo}>1180</div>}
        </div>
      </article>
    ))
  }
</div>
