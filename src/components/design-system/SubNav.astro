---
import { t } from '@/lib/i18n/t';
import styles from './SubNav.module.css';

interface SubNavAnchor {
  readonly href: string;
  readonly section: 'why' | 'how' | 'what' | 'tokens' | 'build';
  readonly num: string;
  readonly labelKey:
    | 'theSystem.subnav.why'
    | 'theSystem.subnav.how'
    | 'theSystem.subnav.what'
    | 'theSystem.subnav.tokens'
    | 'theSystem.subnav.build';
}

const ANCHORS: ReadonlyArray<SubNavAnchor> = [
  { href: '#why', section: 'why', num: '01', labelKey: 'theSystem.subnav.why' },
  { href: '#how', section: 'how', num: '02', labelKey: 'theSystem.subnav.how' },
  { href: '#what', section: 'what', num: '03', labelKey: 'theSystem.subnav.what' },
  { href: '#tokens', section: 'tokens', num: '04', labelKey: 'theSystem.subnav.tokens' },
  { href: '#build', section: 'build', num: '05', labelKey: 'theSystem.subnav.build' },
];

const ariaLabelEs = 'Sub-navegación de el sistema';
const ariaLabelEn = 'The system sub-navigation';
---

<nav
  class={styles.subnav}
  data-component="the-system-subnav"
  aria-label={`${ariaLabelEs} / ${ariaLabelEn}`}
>
  <div class={`container ${styles.inner}`}>
    {
      ANCHORS.map((anchor, index) => (
        <a
          href={anchor.href}
          class={styles.link}
          data-subnav-section={anchor.section}
          {...(index === 0 ? { 'data-subnav-active': '' } : {})}
        >
          <span class={styles.num}>{anchor.num}</span>
          <span lang="es">{t(anchor.labelKey, 'es')}</span>
          <span lang="en">{t(anchor.labelKey, 'en')}</span>
        </a>
      ))
    }
  </div>
</nav>

<script>
  import { pickActiveSection, type SectionVisibility } from '@/lib/scroll/active-section';

  const ROOT_SELECTOR = '[data-component="the-system-subnav"]';
  const SECTION_IDS: ReadonlyArray<string> = ['why', 'how', 'what', 'tokens', 'build'];

  function setActiveLink(root: HTMLElement, sectionId: string | null): void {
    const links = root.querySelectorAll<HTMLAnchorElement>('[data-subnav-section]');
    links.forEach((link) => {
      if (link.dataset.subnavSection === sectionId) {
        link.setAttribute('data-subnav-active', '');
      } else {
        link.removeAttribute('data-subnav-active');
      }
    });
  }

  function readEntries(): Map<string, { isIntersecting: boolean; intersectionRatio: number }> {
    const map = new Map<string, { isIntersecting: boolean; intersectionRatio: number }>();
    for (const id of SECTION_IDS) {
      const target = document.getElementById(id);
      if (target === null) {
        continue;
      }
      map.set(id, { isIntersecting: false, intersectionRatio: 0 });
    }
    return map;
  }

  function mountSubNav(): void {
    const root = document.querySelector<HTMLElement>(ROOT_SELECTOR);
    if (root === null) {
      return;
    }
    const visibility = readEntries();
    let lastActive: string | null = SECTION_IDS[0] ?? null;

    const observer = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          const target = entry.target as HTMLElement;
          const id = target.id;
          visibility.set(id, {
            isIntersecting: entry.isIntersecting,
            intersectionRatio: entry.intersectionRatio,
          });
        }
        const ordered: SectionVisibility[] = [];
        for (const id of SECTION_IDS) {
          const value = visibility.get(id);
          if (value !== undefined) {
            ordered.push({
              id,
              isIntersecting: value.isIntersecting,
              intersectionRatio: value.intersectionRatio,
            });
          }
        }
        const next = pickActiveSection(ordered, lastActive);
        if (next !== lastActive) {
          lastActive = next;
          setActiveLink(root, next);
        }
      },
      { rootMargin: '-30% 0px -60% 0px', threshold: [0, 0.25, 0.5, 0.75, 1] },
    );

    for (const id of SECTION_IDS) {
      const target = document.getElementById(id);
      if (target !== null) {
        observer.observe(target);
      }
    }

    const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)');
    const links = root.querySelectorAll<HTMLAnchorElement>('[data-subnav-section]');
    links.forEach((link) => {
      link.addEventListener('click', (event) => {
        const href = link.getAttribute('href');
        if (href === null) {
          return;
        }
        const id = href.slice(1);
        const target = document.getElementById(id);
        if (target === null) {
          return;
        }
        event.preventDefault();
        const top = target.getBoundingClientRect().top + window.scrollY - 96;
        window.scrollTo({ top, behavior: reduceMotion.matches ? 'auto' : 'smooth' });
      });
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', mountSubNav, { once: true });
  } else {
    mountSubNav();
  }
</script>
