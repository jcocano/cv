---
import AgentsMcpIcon from '@/components/ui/icons/AgentsMcpIcon.astro';
import AssistedDevIcon from '@/components/ui/icons/AssistedDevIcon.astro';
import DocumentIcon from '@/components/ui/icons/DocumentIcon.astro';
import EmailIcon from '@/components/ui/icons/EmailIcon.astro';
import GithubIcon from '@/components/ui/icons/GithubIcon.astro';
import LinkedinIcon from '@/components/ui/icons/LinkedinIcon.astro';
import MoonIcon from '@/components/ui/icons/MoonIcon.astro';
import MultiProviderIcon from '@/components/ui/icons/MultiProviderIcon.astro';
import PaperIcon from '@/components/ui/icons/PaperIcon.astro';
import RagCitationIcon from '@/components/ui/icons/RagCitationIcon.astro';
import RepoIcon from '@/components/ui/icons/RepoIcon.astro';
import SparkleIcon from '@/components/ui/icons/SparkleIcon.astro';
import SunIcon from '@/components/ui/icons/SunIcon.astro';
import styles from './UiGallery.module.css';

interface IconEntry {
  readonly id: string;
  readonly name: string;
}

const ICON_ENTRIES: ReadonlyArray<IconEntry> = [
  { id: 'ui-agents-mcp-icon', name: 'AgentsMcpIcon' },
  { id: 'ui-assisted-dev-icon', name: 'AssistedDevIcon' },
  { id: 'ui-document-icon', name: 'DocumentIcon' },
  { id: 'ui-email-icon', name: 'EmailIcon' },
  { id: 'ui-github-icon', name: 'GithubIcon' },
  { id: 'ui-linkedin-icon', name: 'LinkedinIcon' },
  { id: 'ui-moon-icon', name: 'MoonIcon' },
  { id: 'ui-multi-provider-icon', name: 'MultiProviderIcon' },
  { id: 'ui-paper-icon', name: 'PaperIcon' },
  { id: 'ui-rag-citation-icon', name: 'RagCitationIcon' },
  { id: 'ui-repo-icon', name: 'RepoIcon' },
  { id: 'ui-sparkle-icon', name: 'SparkleIcon' },
  { id: 'ui-sun-icon', name: 'SunIcon' },
];
---

<div class={styles.gallery}>
  <div class={styles.specGrid} data-ui-group="primitives" data-grid-shape="spec">
    <article class={styles.specCell} data-ui-entry="ui-eyebrow">
      <div class={styles.label}>
        <h4 class={styles.name} id="ui-eyebrow">Eyebrow</h4>
      </div>
      <div class={styles.stage}>
        <span class={styles.primEyebrow}>
          <span class={styles.primEyebrowNum}>01</span>
          <span lang="es">muestra</span>
          <span lang="en">preview</span>
        </span>
      </div>
    </article>

    <article class={styles.specCell} data-ui-entry="ui-lang">
      <div class={styles.label}>
        <h4 class={styles.name} id="ui-lang">Lang</h4>
      </div>
      <div class={styles.stageColumn}>
        <span lang="es" class={styles.langDemoEs}>muestra bilingüe</span>
        <span lang="en" class={styles.langDemoEn}>bilingual preview</span>
      </div>
    </article>

    <article class={styles.specCell} data-ui-entry="ui-tag">
      <div class={styles.label}>
        <h4 class={styles.name} id="ui-tag">Tag</h4>
      </div>
      <div class={styles.stage}>
        <span class={styles.primTag}>Tag preview</span>
      </div>
    </article>

    <article class={styles.specCell} data-ui-entry="ui-section-head">
      <div class={styles.label}>
        <h4 class={styles.name} id="ui-section-head">SectionHead</h4>
      </div>
      <div class={styles.stage}>
        <div class={styles.primSectionHead}>
          <div class={styles.primSectionHeadEy}>
            <span class={styles.primSectionHeadEyNum}>01</span>
            <span lang="es">muestra</span>
            <span lang="en">preview</span>
          </div>
          <div class={styles.primSectionHeadTitle}>
            <span lang="es">Título de muestra</span>
            <span lang="en">Sample title</span>
          </div>
        </div>
      </div>
    </article>
  </div>

  <div class={styles.iconsGrid} data-ui-group="icons" data-grid-shape="icons">
    {
      ICON_ENTRIES.map((iconEntry) => (
        <article class={styles.iconCell} data-ui-entry={iconEntry.id}>
          <div class={styles.iconSvg}>
            {iconEntry.id === 'ui-agents-mcp-icon' && <AgentsMcpIcon />}
            {iconEntry.id === 'ui-assisted-dev-icon' && <AssistedDevIcon />}
            {iconEntry.id === 'ui-document-icon' && <DocumentIcon />}
            {iconEntry.id === 'ui-email-icon' && <EmailIcon />}
            {iconEntry.id === 'ui-github-icon' && <GithubIcon />}
            {iconEntry.id === 'ui-linkedin-icon' && <LinkedinIcon />}
            {iconEntry.id === 'ui-moon-icon' && <MoonIcon />}
            {iconEntry.id === 'ui-multi-provider-icon' && <MultiProviderIcon />}
            {iconEntry.id === 'ui-paper-icon' && <PaperIcon />}
            {iconEntry.id === 'ui-rag-citation-icon' && <RagCitationIcon />}
            {iconEntry.id === 'ui-repo-icon' && <RepoIcon />}
            {iconEntry.id === 'ui-sparkle-icon' && <SparkleIcon />}
            {iconEntry.id === 'ui-sun-icon' && <SunIcon />}
          </div>
          <h4 class={styles.iconName} id={iconEntry.id}>
            {iconEntry.name}
          </h4>
        </article>
      ))
    }
  </div>
</div>
