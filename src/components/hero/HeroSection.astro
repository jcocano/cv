---
import heroJson from '@/data/hero.json';
import { buildAscii } from '@/lib/hero/build-ascii';
import { heroSchema, type Hero } from '@/lib/schemas/hero';
import { t } from '@/lib/i18n/t';
import { isLangCode, type LangCode } from '@/lib/theme/toggle-lang';

interface Props {
  lang?: LangCode;
}

const { lang } = Astro.props;
const activeLang: LangCode = isLangCode(lang) ? lang : 'es';

const hero: Hero = heroSchema.parse(heroJson);

const heroAsciiPattern = buildAscii(80, 60);
const avatarSrc = `${import.meta.env.BASE_URL}pfp.jpeg`;
---

<header class="hero" id="top">
  <div class="hero-bg" aria-hidden="true">{heroAsciiPattern}</div>
  <div class="container">
    <div class="hero-grid">
      <div>
        <div class="hero-eyebrow-row">
          <span class="eyebrow">
            <span class="num">01</span> /
            <span lang="es">{t('hero.eyebrow', 'es')}</span>
            <span lang="en">{t('hero.eyebrow', 'en')}</span>
          </span>
          <span class="ai-badge" title={t('hero.aiReady', activeLang)}>
            <svg
              class="sparkle"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.8"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <path
                d="M12 3v4M12 17v4M3 12h4M17 12h4M5.6 5.6l2.8 2.8M15.6 15.6l2.8 2.8M5.6 18.4l2.8-2.8M15.6 8.4l2.8-2.8"
              ></path>
            </svg>
            {t('hero.aiReady', activeLang)}
          </span>
        </div>

        <h1>
          Jesús<br />Cocaño<span class="accent">.</span>
        </h1>

        <p class="hero-pitch">
          <span lang="es">{hero.pitch.es}</span>
          <span lang="en">{hero.pitch.en}</span>
        </p>

        <div class="hero-meta">
          <div class="item">
            <span class="k">
              <span lang="es">{t('hero.meta.location', 'es')}</span>
              <span lang="en">{t('hero.meta.location', 'en')}</span>
            </span>
            <span class="v">
              <span lang="es">{hero.location.es}</span>
              <span lang="en">{hero.location.en}</span>
            </span>
          </div>
          <div class="item">
            <span class="k">
              <span lang="es">{t('hero.meta.status', 'es')}</span>
              <span lang="en">{t('hero.meta.status', 'en')}</span>
            </span>
            <span class="v live">
              <span lang="es">{hero.status.es}</span>
              <span lang="en">{hero.status.en}</span>
            </span>
          </div>
          <div class="item">
            <span class="k">
              <span lang="es">{t('hero.meta.role', 'es')}</span>
              <span lang="en">{t('hero.meta.role', 'en')}</span>
            </span>
            <span class="v">{hero.roleShort}</span>
          </div>
          <div class="item">
            <span class="k">{t('hero.meta.ai', activeLang)}</span>
            <span class="v">
              <span lang="es">{hero.aiTopics.es}</span>
              <span lang="en">{hero.aiTopics.en}</span>
            </span>
          </div>
        </div>
      </div>

      <aside class="hero-card" aria-label="Profile card">
        <div class="pfp">
          <img src={avatarSrc} alt={hero.name} />
        </div>
        <div class="links">
          <a href={hero.links.email} title="Email">
            <svg
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.6"
              aria-hidden="true"
            >
              <rect x="3" y="5" width="18" height="14" rx="2"></rect>
              <path d="m3 7 9 6 9-6"></path>
            </svg>
            Email
          </a>
          <a href={hero.links.github} target="_blank" rel="noopener noreferrer" title="GitHub">
            <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path
                d="M12 2a10 10 0 0 0-3.16 19.49c.5.09.68-.22.68-.48v-1.7c-2.78.6-3.37-1.34-3.37-1.34-.45-1.16-1.11-1.46-1.11-1.46-.91-.62.07-.6.07-.6 1 .07 1.53 1.03 1.53 1.03.89 1.53 2.34 1.09 2.91.83.09-.65.35-1.09.63-1.34-2.22-.25-4.55-1.11-4.55-4.94 0-1.09.39-1.98 1.03-2.68-.1-.25-.45-1.27.1-2.65 0 0 .84-.27 2.75 1.02a9.5 9.5 0 0 1 5 0c1.91-1.29 2.75-1.02 2.75-1.02.55 1.38.2 2.4.1 2.65.64.7 1.03 1.59 1.03 2.68 0 3.84-2.34 4.69-4.57 4.93.36.31.68.92.68 1.85v2.74c0 .27.18.58.69.48A10 10 0 0 0 12 2z"
              ></path>
            </svg>
            GitHub
          </a>
          <a
            class="full"
            href={hero.links.linkedin}
            target="_blank"
            rel="noopener noreferrer"
            title="LinkedIn"
          >
            <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path
                d="M19 3H5a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V5a2 2 0 0 0-2-2zM8.34 18.34H5.67V9.67h2.67v8.67zM7 8.5a1.55 1.55 0 1 1 0-3.1 1.55 1.55 0 0 1 0 3.1zm11.34 9.84h-2.67v-4.22c0-1-.02-2.3-1.4-2.3-1.4 0-1.62 1.1-1.62 2.23v4.29h-2.67V9.67h2.56v1.18h.04c.36-.68 1.23-1.4 2.54-1.4 2.71 0 3.22 1.79 3.22 4.11v4.78z"
              ></path>
            </svg>
            LinkedIn
          </a>
        </div>
      </aside>
    </div>
  </div>
</header>

<style>
  .hero {
    padding: 80px 0 100px;
    border-bottom: 1px solid var(--line-soft);
    position: relative;
    overflow: hidden;
    isolation: isolate;
  }
  .container {
    max-width: var(--container);
    margin: 0 auto;
    padding: 0 28px;
  }
  .hero-grid {
    display: grid;
    grid-template-columns: 1fr 280px;
    gap: 60px;
    align-items: end;
  }
  .hero-eyebrow-row {
    display: flex;
    gap: 10px;
    align-items: center;
    flex-wrap: wrap;
    margin-bottom: 4px;
  }
  .eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--fg-dim);
  }
  .eyebrow::before {
    content: '';
    width: 18px;
    height: 1px;
    background: var(--fg-mute);
  }
  .eyebrow .num {
    color: var(--accent);
  }
  .ai-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 6px 12px;
    border: 1px solid var(--accent);
    border-radius: 100px;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--accent);
    background: var(--accent-dim);
    position: relative;
    overflow: hidden;
  }
  .ai-badge::before {
    content: '';
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--accent);
    box-shadow: 0 0 0 3px color-mix(in oklab, var(--accent) 25%, transparent);
    animation: hero-pulse 2s infinite;
  }
  .ai-badge .sparkle {
    width: 12px;
    height: 12px;
    margin-right: -2px;
  }
  .hero h1 {
    font-size: clamp(48px, 8vw, 96px);
    line-height: 0.96;
    letter-spacing: -0.04em;
    margin: 18px 0 28px;
    font-weight: 500;
  }
  .hero h1 .accent {
    color: var(--accent);
    font-style: italic;
    font-weight: 400;
  }
  .hero-pitch {
    max-width: 56ch;
    font-size: 18px;
    color: var(--fg-dim);
    line-height: 1.55;
    margin: 0;
  }
  .hero-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 24px 32px;
    margin-top: 36px;
    align-items: center;
  }
  .hero-meta .item {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .hero-meta .item .k {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--fg-mute);
  }
  .hero-meta .item .v {
    font-size: 14px;
    color: var(--fg);
  }
  .hero-meta .item .v.live {
    display: inline-flex;
    align-items: center;
    gap: 8px;
  }
  .hero-meta .item .v.live::before {
    content: '';
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--accent);
    box-shadow: 0 0 0 3px color-mix(in oklab, var(--accent) 25%, transparent);
    animation: hero-pulse 2s infinite;
  }
  .hero-card {
    border: 1px solid var(--line);
    border-radius: var(--radius-lg);
    padding: 18px;
    background: var(--bg-elev);
    display: flex;
    flex-direction: column;
    gap: 14px;
  }
  .hero-card .pfp {
    width: 100%;
    aspect-ratio: 1;
    border-radius: var(--radius);
    background: var(--bg-elev-2);
    overflow: hidden;
    position: relative;
  }
  .hero-card .pfp img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: grayscale(0.15) contrast(1.05);
    transition: filter 0.3s;
  }
  .hero-card:hover .pfp img {
    filter: grayscale(0) contrast(1);
  }
  .hero-card .pfp::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(
      135deg,
      transparent 60%,
      color-mix(in oklab, var(--accent) 18%, transparent)
    );
    pointer-events: none;
  }
  .hero-card .links {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 6px;
  }
  .hero-card .links a {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
    padding: 9px;
    border: 1px solid var(--line);
    border-radius: 6px;
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--fg-dim);
    transition: all 0.15s;
  }
  .hero-card .links a:hover,
  .hero-card .links a:focus-visible {
    color: var(--fg);
    border-color: var(--accent);
    background: var(--accent-dim);
  }
  .hero-card .links a.full {
    grid-column: span 2;
  }
  .hero-card .links a svg {
    width: 12px;
    height: 12px;
  }
  .hero-bg {
    position: absolute;
    right: 0;
    top: 0;
    bottom: 0;
    width: 50%;
    max-width: 600px;
    pointer-events: none;
    opacity: 0.04;
    font-family: var(--font-mono);
    font-size: 11px;
    line-height: 1.2;
    color: var(--fg);
    white-space: pre;
    user-select: none;
    overflow: hidden;
    z-index: -1;
    mask-image: linear-gradient(to left, black 40%, transparent 100%);
    -webkit-mask-image: linear-gradient(to left, black 40%, transparent 100%);
  }
  @keyframes hero-pulse {
    0%,
    100% {
      opacity: 1;
    }
    50% {
      opacity: 0.5;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .ai-badge::before,
    .hero-meta .item .v.live::before {
      animation: none;
    }
  }
  @media (max-width: 860px) {
    .hero-grid {
      grid-template-columns: 1fr;
      gap: 40px;
    }
    .hero {
      padding: 56px 0 64px;
    }
  }
  @media (max-width: 640px) {
    .container {
      padding: 0 20px;
    }
  }
</style>
