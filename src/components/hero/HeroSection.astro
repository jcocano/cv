---
import AiBadge from '@/components/hero/AiBadge.astro';
import HeroCard from '@/components/hero/HeroCard.astro';
import HeroMeta, { type HeroMetaItem } from '@/components/hero/HeroMeta.astro';
import Eyebrow from '@/components/ui/Eyebrow.astro';
import heroJson from '@/data/hero.json';
import { buildAscii } from '@/lib/hero/build-ascii';
import { heroSchema, type Hero } from '@/lib/schemas/hero';
import { t } from '@/lib/i18n/t';
import { isLangCode, type LangCode } from '@/lib/theme/toggle-lang';

interface Props {
  lang?: LangCode;
}

const { lang } = Astro.props;
const activeLang: LangCode = isLangCode(lang) ? lang : 'es';

const hero: Hero = heroSchema.parse(heroJson);

const heroAsciiPattern = buildAscii(80, 60);
const avatarSrc = `${import.meta.env.BASE_URL}pfp.jpeg`;

const metaItems: HeroMetaItem[] = [
  {
    label: { es: t('hero.meta.location', 'es'), en: t('hero.meta.location', 'en') },
    value: hero.location,
  },
  {
    label: { es: t('hero.meta.status', 'es'), en: t('hero.meta.status', 'en') },
    value: hero.status,
    live: true,
  },
  {
    label: { es: t('hero.meta.role', 'es'), en: t('hero.meta.role', 'en') },
    value: hero.roleShort,
  },
  {
    label: t('hero.meta.ai', activeLang),
    value: hero.aiTopics,
  },
];
---

<header class="hero" id="top">
  <div class="hero-bg" aria-hidden="true">{heroAsciiPattern}</div>
  <div class="container">
    <div class="hero-grid">
      <div>
        <div class="hero-eyebrow-row">
          <Eyebrow num="01" labelEs={t('hero.eyebrow', 'es')} labelEn={t('hero.eyebrow', 'en')} />
          <AiBadge label={t('hero.aiReady', activeLang)} />
        </div>

        <h1>
          Jesús<br />Cocaño<span class="accent">.</span>
        </h1>

        <p class="hero-pitch">
          <span lang="es">{hero.pitch.es}</span>
          <span lang="en">{hero.pitch.en}</span>
        </p>

        <HeroMeta items={metaItems} />
      </div>

      <HeroCard name={hero.name} avatarSrc={avatarSrc} links={hero.links} />
    </div>
  </div>
</header>

<style>
  .hero {
    padding: 80px 0 100px;
    border-bottom: 1px solid var(--line-soft);
    position: relative;
    overflow: hidden;
    isolation: isolate;
  }
  .hero-grid {
    display: grid;
    grid-template-columns: 1fr 280px;
    gap: 60px;
    align-items: end;
  }
  .hero-eyebrow-row {
    display: flex;
    gap: 10px;
    align-items: center;
    flex-wrap: wrap;
    margin-bottom: 4px;
  }
  .hero h1 {
    font-size: clamp(48px, 8vw, 96px);
    line-height: 0.96;
    letter-spacing: -0.04em;
    margin: 18px 0 28px;
    font-weight: 500;
  }
  .hero h1 .accent {
    color: var(--accent);
    font-style: italic;
    font-weight: 400;
  }
  .hero-pitch {
    max-width: 56ch;
    font-size: 18px;
    color: var(--fg-dim);
    line-height: 1.55;
    margin: 0;
  }
  .hero-bg {
    position: absolute;
    right: 0;
    top: 0;
    bottom: 0;
    width: 50%;
    max-width: 600px;
    pointer-events: none;
    opacity: 0.04;
    font-family: var(--font-mono);
    font-size: 11px;
    line-height: 1.2;
    color: var(--fg);
    white-space: pre;
    user-select: none;
    overflow: hidden;
    z-index: -1;
    mask-image: linear-gradient(to left, black 40%, transparent 100%);
    -webkit-mask-image: linear-gradient(to left, black 40%, transparent 100%);
  }
  @media (max-width: 860px) {
    .hero-grid {
      grid-template-columns: 1fr;
      gap: 40px;
    }
    .hero {
      padding: 56px 0 64px;
    }
  }
</style>
