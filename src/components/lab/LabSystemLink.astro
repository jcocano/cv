---
import { t } from '@/lib/i18n/t';
import styles from './LabSystemLink.module.css';

const href = `${import.meta.env.BASE_URL}the-system/`;
---

<div class={styles.systemLinkWrap}>
  <a class={styles.systemLink} href={href}>
    <span lang="es">{t('lab.systemLink', 'es')}</span>
    <span lang="en">{t('lab.systemLink', 'en')}</span>
  </a>
</div>
