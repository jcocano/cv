---
import MoonIcon from '@/components/ui/icons/MoonIcon.astro';
import PaperIcon from '@/components/ui/icons/PaperIcon.astro';
import SunIcon from '@/components/ui/icons/SunIcon.astro';
import { isHomePath } from '@/lib/nav/is-home-path';
import { resolveBrandHref, resolveHomeSectionHref } from '@/lib/nav/resolve-nav-href';
import styles from './SiteNav.module.css';

const baseUrl = import.meta.env.BASE_URL;
const cvHref = `${baseUrl}jesus_cocano_cv.pdf`;
const isHome = isHomePath(Astro.url.pathname, baseUrl);
const brandHref = resolveBrandHref(isHome, baseUrl);
const aboutHref = resolveHomeSectionHref('#about', isHome, baseUrl);
const experienceHref = resolveHomeSectionHref('#experience', isHome, baseUrl);
const stackHref = resolveHomeSectionHref('#stack', isHome, baseUrl);
const workHref = resolveHomeSectionHref('#work', isHome, baseUrl);
const contactHref = resolveHomeSectionHref('#contact', isHome, baseUrl);
---

<nav class={styles.nav} aria-label="Primary">
  <div class:list={[styles.navInner, 'container']}>
    <div class={styles.navBrand}>
      <a class={styles.navBrandLogo} href={brandHref}>
        <span class="dot"></span>
        <span>jcocano</span>
      </a>
      <span style="color: var(--fg-mute);">/</span>
      <a
        class={styles.navBrandCv}
        href={cvHref}
        target="_blank"
        rel="noopener"
        download
        aria-label="Download CV"
        title="Download CV">cv</a
      >
    </div>
    <div class={styles.navLinks}>
      <a class="nav-link" href={aboutHref}>
        <span class="num">01</span>
        <span lang="es">Acerca</span>
        <span lang="en">About</span>
      </a>
      <a class="nav-link" href={experienceHref}>
        <span class="num">02</span>
        <span lang="es">Experiencia</span>
        <span lang="en">Experience</span>
      </a>
      <a class="nav-link" href={stackHref}>
        <span class="num">03</span>
        <span lang="es">Stack</span>
        <span lang="en">Stack</span>
      </a>
      <a class="nav-link" href={workHref}>
        <span class="num">04</span>
        <span lang="es">Proyectos</span>
        <span lang="en">Work</span>
      </a>
      <a class="nav-link" href={contactHref}>
        <span class="num">05</span>
        <span lang="es">Contacto</span>
        <span lang="en">Contact</span>
      </a>
    </div>
    <div class={styles.navTools}>
      <button
        type="button"
        class={styles.langBtn}
        id="lang-toggle"
        aria-label="Toggle language"
        data-shortcut="L"
      >
        <span class="opt" data-l="es">ES</span>
        <span class="opt" data-l="en">EN</span>
      </button>
      <button
        type="button"
        class={styles.iconBtn}
        id="theme-toggle"
        aria-label="Toggle theme"
        title="Cycle theme (dark / light / paper)"
        data-shortcut="T"
      >
        <span class={styles.themeIcon} data-theme-icon="dark"><SunIcon /></span>
        <span class={styles.themeIcon} data-theme-icon="light"><PaperIcon /></span>
        <span class={styles.themeIcon} data-theme-icon="paper"><MoonIcon /></span>
      </button>
    </div>
  </div>
</nav>
