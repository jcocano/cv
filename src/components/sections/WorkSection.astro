---
import { getCollection, type CollectionEntry } from 'astro:content';

import Eyebrow from '@/components/ui/Eyebrow.astro';
import SectionHead from '@/components/ui/SectionHead.astro';
import CaseStudiesBlock from '@/components/work/CaseStudiesBlock.astro';
import MoreProjectsLink from '@/components/work/MoreProjectsLink.astro';
import OssCardList from '@/components/work/OssCardList.astro';
import PublicationsList from '@/components/work/PublicationsList.astro';
import SideProjectRow from '@/components/work/SideProjectRow.astro';
import { validateProjects } from '@/lib/content/validate-projects';
import { t } from '@/lib/i18n/t';
import type { Project } from '@/lib/schemas/projects';
import type { SideProject } from '@/lib/schemas/side-projects';
import styles from './WorkSection.module.css';

const baseUrl = import.meta.env.BASE_URL;

const projectEntries: CollectionEntry<'projects'>[] = await getCollection('projects');
const projects: Project[] = projectEntries.map((entry: CollectionEntry<'projects'>) => entry.data);
validateProjects(projects);

const sideEntries: CollectionEntry<'side-projects'>[] = await getCollection('side-projects');
const sideProjects: SideProject[] = sideEntries
  .map((entry: CollectionEntry<'side-projects'>) => entry.data)
  .sort((a, b) => a.order - b.order);
---

<section id="work">
  <div class="container">
    <SectionHead
      num="04"
      labelEs={t('work.eyebrow', 'es')}
      labelEn={t('work.eyebrow', 'en')}
      titleEs={'Trabajo\nseleccionado.'}
      titleEn={'Selected\nprojects.'}
      ledeEs="Plataformas en producción, decisiones de arquitectura, e impacto medible."
      ledeEn="Production platforms, architectural calls, and measurable impact."
    />

    <CaseStudiesBlock projects={projects} baseUrl={baseUrl} />

    <MoreProjectsLink />

    <div class={styles.ossBlock}>
      <Eyebrow
        num="04.5"
        labelEs={t('work.ossEyebrow', 'es')}
        labelEn={t('work.ossEyebrow', 'en')}
        reveal={true}
      />
      <OssCardList />
    </div>

    <div class={styles.sideBlock}>
      <Eyebrow
        num="04.6"
        labelEs={t('work.sideEyebrow', 'es')}
        labelEn={t('work.sideEyebrow', 'en')}
        reveal={true}
      />
      <div class={`${styles.sideList} reveal`}>
        {sideProjects.map((project) => <SideProjectRow project={project} />)}
      </div>
    </div>

    <div class={styles.pubBlock}>
      <Eyebrow
        num="04.7"
        labelEs={t('work.publicationsEyebrow', 'es')}
        labelEn={t('work.publicationsEyebrow', 'en')}
        reveal={true}
      />
      <PublicationsList />
    </div>
  </div>
</section>
