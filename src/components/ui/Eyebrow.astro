---
import styles from './Eyebrow.module.css';

interface Props {
  num: string;
  labelEs: string;
  labelEn: string;
}

const { num, labelEs, labelEn } = Astro.props;
---

<span class={styles.eyebrow}>
  <span class={styles.num}>{num}</span> /
  <span lang="es">{labelEs}</span>
  <span lang="en">{labelEn}</span>
</span>
