---
import Eyebrow from '@/components/ui/Eyebrow.astro';
import styles from './SectionHead.module.css';

interface Props {
  num: string;
  labelEs: string;
  labelEn: string;
  titleEs: string;
  titleEn: string;
  ledeEs?: string;
  ledeEn?: string;
}

const { num, labelEs, labelEn, titleEs, titleEn, ledeEs, ledeEn } = Astro.props;

const titleEsLines = titleEs.split('\n');
const titleEnLines = titleEn.split('\n');

const hasLedeEs = ledeEs !== undefined && ledeEs !== '';
const hasLedeEn = ledeEn !== undefined && ledeEn !== '';
const showLede = hasLedeEs || hasLedeEn;
---

<div class:list={[styles.sectionHead, 'reveal']}>
  <Eyebrow num={num} labelEs={labelEs} labelEn={labelEn} />
  <div>
    <h2>
      <span lang="es"
        >{
          titleEsLines.map((line, index) => (
            <>
              {index > 0 && <br />}
              {line}
            </>
          ))
        }</span
      >
      <span lang="en"
        >{
          titleEnLines.map((line, index) => (
            <>
              {index > 0 && <br />}
              {line}
            </>
          ))
        }</span
      >
    </h2>
    {
      showLede && (
        <p class={styles.lede}>
          {hasLedeEs && <span lang="es">{ledeEs}</span>}
          {hasLedeEn && <span lang="en">{ledeEn}</span>}
        </p>
      )
    }
  </div>
</div>
