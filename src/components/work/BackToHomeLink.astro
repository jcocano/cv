---
import { t } from '@/lib/i18n/t';
import styles from './BackToHomeLink.module.css';

const href = `${import.meta.env.BASE_URL}`;
---

<div class={styles.wrap}>
  <a class={styles.link} href={href}>
    <span lang="es">{t('projects.backToHome', 'es')}</span>
    <span lang="en">{t('projects.backToHome', 'en')}</span>
  </a>
</div>
