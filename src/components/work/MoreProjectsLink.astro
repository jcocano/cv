---
import { t } from '@/lib/i18n/t';
import styles from './MoreProjectsLink.module.css';

const href = `${import.meta.env.BASE_URL}projects/`;
---

<div class={styles.wrap}>
  <a class={styles.link} href={href}>
    <span lang="es">{t('work.moreProjectsLink', 'es')}</span>
    <span lang="en">{t('work.moreProjectsLink', 'en')}</span>
  </a>
</div>
