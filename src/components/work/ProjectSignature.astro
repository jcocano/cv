---
interface Props {
  slug: string;
}

const { slug } = Astro.props;
---

{
  slug === 'made-by-apes' && (
    <svg
      class="signature"
      viewBox="0 0 200 200"
      fill="none"
      stroke="currentColor"
      stroke-width="0.5"
    >
      <circle cx="100" cy="100" r="80" stroke="var(--accent)" />
      <circle cx="100" cy="100" r="60" stroke="var(--accent)" opacity="0.6" />
      <circle cx="100" cy="100" r="40" stroke="var(--accent)" opacity="0.4" />
      <circle cx="100" cy="100" r="20" fill="var(--accent)" opacity="0.3" />
    </svg>
  )
}
{
  slug === 'cluster-separation' && (
    <svg
      class="signature"
      viewBox="0 0 200 200"
      fill="none"
      stroke="var(--accent)"
      stroke-width="0.6"
    >
      <rect x="20" y="20" width="60" height="60" rx="4" />
      <rect x="120" y="20" width="60" height="60" rx="4" />
      <rect x="20" y="120" width="60" height="60" rx="4" />
      <rect x="120" y="120" width="60" height="60" rx="4" />
      <line x1="80" y1="50" x2="120" y2="50" stroke-dasharray="2 3" />
      <line x1="80" y1="150" x2="120" y2="150" stroke-dasharray="2 3" />
      <line x1="50" y1="80" x2="50" y2="120" stroke-dasharray="2 3" />
      <line x1="150" y1="80" x2="150" y2="120" stroke-dasharray="2 3" />
    </svg>
  )
}
{
  slug === 'incommers-nft' && (
    <svg
      class="signature"
      viewBox="0 0 200 200"
      fill="none"
      stroke="var(--accent)"
      stroke-width="0.6"
    >
      <path d="M100 20 L100 50 M70 80 L130 80 M40 110 L70 110 M90 110 L110 110 M130 110 L160 110" />
      <line x1="100" y1="50" x2="70" y2="80" />
      <line x1="100" y1="50" x2="130" y2="80" />
      <line x1="70" y1="80" x2="40" y2="110" />
      <line x1="70" y1="80" x2="100" y2="110" />
      <line x1="130" y1="80" x2="100" y2="110" />
      <line x1="130" y1="80" x2="160" y2="110" />
      <circle cx="40" cy="110" r="4" fill="var(--accent)" />
      <circle cx="100" cy="110" r="4" fill="var(--accent)" />
      <circle cx="160" cy="110" r="4" fill="var(--accent)" />
      <circle cx="100" cy="50" r="4" fill="var(--accent)" />
    </svg>
  )
}
{
  slug !== 'made-by-apes' && slug !== 'cluster-separation' && slug !== 'incommers-nft' && (
    <svg
      class="signature"
      viewBox="0 0 200 200"
      fill="none"
      stroke="var(--accent)"
      stroke-width="0.6"
    >
      <circle cx="100" cy="100" r="80" />
      <rect x="50" y="50" width="100" height="100" />
      <line x1="20" y1="100" x2="180" y2="100" stroke-dasharray="2 3" />
      <line x1="100" y1="20" x2="100" y2="180" stroke-dasharray="2 3" />
    </svg>
  )
}
