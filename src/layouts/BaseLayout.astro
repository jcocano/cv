---
import '@/styles/tokens.css';
import '@/styles/base.css';
import SiteNav from '@/components/nav/SiteNav.astro';
import { CONSOLE_SIGNATURE } from '@/lib/runtime/console-signature';
import { WINDOW_ENVS_PAYLOAD } from '@/lib/runtime/window-envs';
import styles from './BaseLayout.module.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Jesus Cocano — CV',
  description = 'Senior Fullstack & Platform Engineer — CV and portfolio.',
} = Astro.props;

const consoleSignatureFormat = CONSOLE_SIGNATURE.format;
const consoleSignatureStyles = CONSOLE_SIGNATURE.styles;
const windowEnvsPayload = WINDOW_ENVS_PAYLOAD;
---

<!doctype html>
<html lang="es" data-theme="dark" data-lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>

    <script is:inline>
      (function applyStoredPreferencesBeforePaint() {
        const validThemes = ['dark', 'light', 'paper'];
        const validLangs = ['es', 'en'];
        const root = document.documentElement;
        try {
          const storedTheme = localStorage.getItem('theme');
          const theme = validThemes.indexOf(storedTheme) >= 0 ? storedTheme : 'dark';
          root.setAttribute('data-theme', theme);
          const storedLang = localStorage.getItem('lang');
          const lang = validLangs.indexOf(storedLang) >= 0 ? storedLang : 'es';
          root.setAttribute('data-lang', lang);
          root.setAttribute('lang', lang);
        } catch {
          root.setAttribute('data-theme', 'dark');
          root.setAttribute('data-lang', 'es');
          root.setAttribute('lang', 'es');
        }
      })();
    </script>

    <script is:inline define:vars={{ consoleSignatureFormat, consoleSignatureStyles }}>
      (function showConsoleSignatureOnce() {
        if (window.__cv_signature_shown === true) {
          return;
        }
        window.__cv_signature_shown = true;
        // eslint-disable-next-line no-console
        console.info(consoleSignatureFormat, ...consoleSignatureStyles);
      })();
    </script>

    <script is:inline define:vars={{ windowEnvsPayload }}>
      (function applyWindowEnvsOnLoad() {
        window.envs = windowEnvsPayload;
      })();
    </script>
  </head>
  <body>
    <a class={styles.skipLink} href="#main">Skip to content</a>

    <SiteNav />

    <main id="main">
      <slot />
    </main>

    <footer class={`${styles.siteFooter} mono`}>
      <div class={styles.siteFooterInner}>
        <span>© <span data-current-year></span> Jesus Cocano</span>
        <span>⌨ T theme · L lang</span>
      </div>
    </footer>

    <style is:global>
      ::view-transition-old(root),
      ::view-transition-new(root) {
        animation-duration: 200ms;
      }
      @media (prefers-reduced-motion: reduce) {
        ::view-transition-old(root),
        ::view-transition-new(root) {
          animation: none;
        }
      }
    </style>

    <script>
      import { currentYear } from '@/lib/footer-utils/current-year';
      import { collectScrollspyTargetsFromNavLinks } from '@/lib/motion/collect-scrollspy-targets';
      import { mountReveal } from '@/lib/motion/reveal';
      import { mountScrollspy } from '@/lib/motion/mount-scrollspy';
      import { shouldReduceMotion } from '@/lib/motion/should-reduce-motion';
      import { applyLangActive } from '@/lib/theme/apply-lang-active';
      import { isThemeName, nextTheme, type ThemeName } from '@/lib/theme/next-theme';
      import { isLangCode, toggleLang, type LangCode } from '@/lib/theme/toggle-lang';

      const THEME_STORAGE_KEY = 'theme';
      const LANG_STORAGE_KEY = 'lang';
      const root = document.documentElement;

      function readCurrentTheme(): ThemeName {
        const attr = root.getAttribute('data-theme');
        return isThemeName(attr) ? attr : 'dark';
      }

      function readCurrentLang(): LangCode {
        const attr = root.getAttribute('data-lang');
        return isLangCode(attr) ? attr : 'es';
      }

      function applyTheme(theme: ThemeName): void {
        root.setAttribute('data-theme', theme);
        try {
          localStorage.setItem(THEME_STORAGE_KEY, theme);
        } catch {
          /* localStorage may be unavailable (private mode); ignore. */
        }
      }

      function applyLang(lang: LangCode): void {
        root.setAttribute('data-lang', lang);
        root.setAttribute('lang', lang);
        try {
          localStorage.setItem(LANG_STORAGE_KEY, lang);
        } catch {
          /* localStorage may be unavailable (private mode); ignore. */
        }
        const langOptions = document.querySelectorAll<HTMLElement>('#lang-toggle .opt');
        applyLangActive(langOptions, lang);
      }

      function cycleTheme(): void {
        const next = nextTheme(readCurrentTheme());
        const supportsViewTransitions =
          'startViewTransition' in document && typeof document.startViewTransition === 'function';
        if (supportsViewTransitions) {
          document.startViewTransition(() => applyTheme(next));
          return;
        }
        applyTheme(next);
      }

      function flipLang(): void {
        applyLang(toggleLang(readCurrentLang()));
      }

      const themeButton = document.getElementById('theme-toggle');
      const langButton = document.getElementById('lang-toggle');
      themeButton?.addEventListener('click', cycleTheme);
      langButton?.addEventListener('click', flipLang);

      function isTypingTarget(target: EventTarget | null): boolean {
        if (!(target instanceof HTMLElement)) {
          return false;
        }
        const tag = target.tagName;
        if (tag === 'INPUT' || tag === 'TEXTAREA' || tag === 'SELECT') {
          return true;
        }
        return target.isContentEditable;
      }

      document.addEventListener('keydown', (event) => {
        if (event.metaKey || event.ctrlKey || event.altKey) {
          return;
        }
        if (isTypingTarget(event.target)) {
          return;
        }
        const key = event.key.toLowerCase();
        if (key === 't') {
          event.preventDefault();
          cycleTheme();
          return;
        }
        if (key === 'l') {
          event.preventDefault();
          flipLang();
        }
      });

      applyTheme(readCurrentTheme());
      applyLang(readCurrentLang());

      const yearSlots = document.querySelectorAll<HTMLElement>('[data-current-year]');
      const currentYearText = String(currentYear());
      yearSlots.forEach((node) => {
        node.textContent = currentYearText;
      });

      const reducedMotionQuery = window.matchMedia('(prefers-reduced-motion: reduce)');
      if (!shouldReduceMotion(reducedMotionQuery)) {
        mountReveal();
      }

      const scrollspyNavLinks = document.querySelectorAll<HTMLAnchorElement>('nav a.nav-link');
      const scrollspyTargets = collectScrollspyTargetsFromNavLinks(scrollspyNavLinks);
      mountScrollspy(scrollspyNavLinks, scrollspyTargets);
    </script>
  </body>
</html>
