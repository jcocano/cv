---
import HeroSection from '@/components/hero/HeroSection.astro';
import AiReadySection from '@/components/sections/AiReadySection.astro';
import ExperienceSection from '@/components/sections/ExperienceSection.astro';
import LabSection from '@/components/sections/LabSection.astro';
import SummarySection from '@/components/sections/SummarySection.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';

const tokenNames = [
  'bg',
  'bg-elev',
  'bg-elev-2',
  'fg',
  'fg-dim',
  'fg-mute',
  'line',
  'line-soft',
  'accent',
  'accent-dim',
  'warn',
] as const;

const themes = ['dark', 'light', 'paper'] as const;
---

<BaseLayout title="Jesús Cocaño — Senior Fullstack & Platform Engineer">
  <HeroSection />

  <div id="about">
    <SummarySection />
    <AiReadySection />
    <LabSection />
    <ExperienceSection />
  </div>

  <div class="page">
    <header class="page-head">
      <h1>Design tokens</h1>
      <p class="mono">
        Active theme: <span data-toggle-theme-label>dark</span>
      </p>
      <p class="mono note">
        Cycle the theme with the button in the nav or by pressing <kbd>T</kbd>.
      </p>
    </header>

    {
      themes.map((theme) => (
        <div class="theme-block" data-theme-preview={theme}>
          <h2 class="mono">{theme}</h2>
          <div class="swatches" data-theme={theme}>
            {tokenNames.map((token) => (
              <article class="swatch">
                <span class="chip" style={`background: var(--${token});`} aria-hidden="true" />
                <span class="name mono">{token}</span>
              </article>
            ))}
          </div>
        </div>
      ))
    }
  </div>

  <style>
    .page {
      max-width: var(--container);
      margin: 0 auto;
      padding: 48px 28px;
    }
    .page-head {
      display: flex;
      flex-direction: column;
      gap: 12px;
      margin-bottom: 48px;
    }
    .note {
      font-size: 12px;
      color: var(--fg-mute);
    }
    .note kbd {
      font-family: var(--font-mono);
      font-size: 11px;
      padding: 2px 6px;
      border: 1px solid var(--line);
      border-radius: 4px;
      background: var(--bg-elev);
      color: var(--fg-dim);
    }
    .theme-block {
      margin-bottom: 48px;
      padding: 24px;
      border: 1px solid var(--line);
      border-radius: var(--radius-lg);
      background: var(--bg-elev);
    }
    .theme-block h2 {
      margin: 0 0 16px;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      font-size: 12px;
      color: var(--fg-dim);
    }
    .swatches {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
      gap: 12px;
    }
    .swatch {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 10px;
      border: 1px solid var(--line-soft);
      border-radius: var(--radius);
      background: var(--bg);
    }
    .swatch .chip {
      width: 28px;
      height: 28px;
      border-radius: 6px;
      border: 1px solid var(--line);
      flex-shrink: 0;
    }
    .swatch .name {
      font-size: 12px;
      color: var(--fg-dim);
    }
  </style>
</BaseLayout>
