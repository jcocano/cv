---
import DecisionsList from '@/components/design-system/DecisionsList.astro';
import SiteStatus from '@/components/design-system/SiteStatus.astro';
import SpacingScale from '@/components/design-system/SpacingScale.astro';
import TokenSwatcher from '@/components/design-system/TokenSwatcher.astro';
import TypeScale from '@/components/design-system/TypeScale.astro';
import UiGallery from '@/components/design-system/UiGallery.astro';
import PrinciplesList from '@/components/principles/PrinciplesList.astro';
import principlesJson from '@/data/principles.json';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { t } from '@/lib/i18n/t';
import { principlesSchema } from '@/lib/schemas/principles';
import styles from './index.module.css';

const parsed = principlesSchema.parse(principlesJson);
const principles = parsed.principles;
---

<BaseLayout title="The system — Jesús Cocaño">
  <article class={`container ${styles.pageShell}`}>
    <header class={styles.pageHead}>
      <h1 class={styles.pageTitle}>
        <span lang="es">El sistema</span>
        <span lang="en">The system</span>
      </h1>
      <p class={styles.pageLede}>
        <span lang="es"
          >Principios, decisiones, decisiones técnicas y bases (tipografía, espaciado, primitives,
          tokens).</span
        >
        <span lang="en"
          >Principles, decisions, technical decisions and foundations (typography, spacing,
          primitives, tokens).</span
        >
      </p>
    </header>

    <section id="block-principles" class={styles.block}>
      <p class={styles.blockEyebrow}>
        <span lang="es">{t('theSystem.principlesEyebrow', 'es')}</span>
        <span lang="en">{t('theSystem.principlesEyebrow', 'en')}</span>
      </p>
      <h2 class={styles.blockHeading}>
        <span lang="es">{t('theSystem.principlesTitle', 'es')}</span>
        <span lang="en">{t('theSystem.principlesTitle', 'en')}</span>
      </h2>
      <p class={styles.blockLede}>
        <span lang="es">{t('theSystem.principlesLede', 'es')}</span>
        <span lang="en">{t('theSystem.principlesLede', 'en')}</span>
      </p>
      <PrinciplesList principles={principles} />
    </section>

    <section id="block-decisions" class={styles.block}>
      <p class={styles.blockEyebrow}>
        <span lang="es">{t('theSystem.decisionsEyebrow', 'es')}</span>
        <span lang="en">{t('theSystem.decisionsEyebrow', 'en')}</span>
      </p>
      <h2 class={styles.blockHeading}>
        <span lang="es">{t('theSystem.decisionsTitle', 'es')}</span>
        <span lang="en">{t('theSystem.decisionsTitle', 'en')}</span>
      </h2>
      <DecisionsList source="ui" />
    </section>

    <section id="block-technical-decisions" class={styles.block}>
      <p class={styles.blockEyebrow}>
        <span lang="es">{t('theSystem.technicalDecisionsEyebrow', 'es')}</span>
        <span lang="en">{t('theSystem.technicalDecisionsEyebrow', 'en')}</span>
      </p>
      <h2 class={styles.blockHeading}>
        <span lang="es">{t('theSystem.technicalDecisionsTitle', 'es')}</span>
        <span lang="en">{t('theSystem.technicalDecisionsTitle', 'en')}</span>
      </h2>
      <p class={styles.blockLede}>
        <span lang="es">{t('theSystem.technicalDecisionsLede', 'es')}</span>
        <span lang="en">{t('theSystem.technicalDecisionsLede', 'en')}</span>
      </p>
      <DecisionsList source="technical" />
    </section>

    <section id="block-foundations" class={styles.block}>
      <p class={styles.blockEyebrow}>
        <span lang="es">{t('theSystem.foundationsEyebrow', 'es')}</span>
        <span lang="en">{t('theSystem.foundationsEyebrow', 'en')}</span>
      </p>
      <h2 class={styles.blockHeading}>
        <span lang="es">{t('theSystem.foundationsTitle', 'es')}</span>
        <span lang="en">{t('theSystem.foundationsTitle', 'en')}</span>
      </h2>
      <p class={styles.blockLede}>
        <span lang="es">{t('theSystem.foundationsLede', 'es')}</span>
        <span lang="en">{t('theSystem.foundationsLede', 'en')}</span>
      </p>

      <section id="sub-typography" class={styles.subBlock}>
        <h3 class={styles.subBlockHeading}>
          <span lang="es">{t('theSystem.typographyTitle', 'es')}</span>
          <span lang="en">{t('theSystem.typographyTitle', 'en')}</span>
        </h3>
        <TypeScale />
      </section>

      <section id="sub-spacing" class={styles.subBlock}>
        <h3 class={styles.subBlockHeading}>
          <span lang="es">{t('theSystem.spacingTitle', 'es')}</span>
          <span lang="en">{t('theSystem.spacingTitle', 'en')}</span>
        </h3>
        <SpacingScale />
      </section>

      <section id="sub-ui-primitives" class={styles.subBlock}>
        <h3 class={styles.subBlockHeading}>
          <span lang="es">{t('theSystem.uiPrimitivesTitle', 'es')}</span>
          <span lang="en">{t('theSystem.uiPrimitivesTitle', 'en')}</span>
        </h3>
        <UiGallery />
      </section>

      <section id="sub-tokens-by-theme" class={styles.subBlock}>
        <h3 class={styles.subBlockHeading}>
          <span lang="es">{t('theSystem.tokensByThemeTitle', 'es')}</span>
          <span lang="en">{t('theSystem.tokensByThemeTitle', 'en')}</span>
        </h3>
        <TokenSwatcher />
      </section>
    </section>

    <section id="block-status" class={styles.block}>
      <h2 class={styles.blockHeading}>
        <span lang="es">{t('theSystem.statusTitle', 'es')}</span>
        <span lang="en">{t('theSystem.statusTitle', 'en')}</span>
      </h2>
      <p class={styles.blockLede}>
        <span lang="es">{t('theSystem.statusLede', 'es')}</span>
        <span lang="en">{t('theSystem.statusLede', 'en')}</span>
      </p>
      <SiteStatus />
    </section>
  </article>
</BaseLayout>
